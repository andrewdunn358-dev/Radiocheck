{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "training.radiocheck.me" }],
      "destination": "/learning"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "training.radiocheck.me" }],
      "destination": "/learning/:path*"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "lms-admin.radiocheck.me" }],
      "destination": "/lms-admin"
    },
    {
      "source": "/:path*", 
      "has": [{ "type": "host", "value": "lms-admin.radiocheck.me" }],
      "destination": "/lms-admin/:path*"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "staff.radiocheck.me" }],
      "destination": "/staff"
    },
    {
      "source": "/:path*", 
      "has": [{ "type": "host", "value": "staff.radiocheck.me" }],
      "destination": "/staff/:path*"
    }
  ]
}
